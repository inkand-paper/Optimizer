# ─────────────────────────────────────────────
# NexPulse Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────

# ── Database (Required) ──────────────────────
# PostgreSQL connection string (Supabase, Railway, Neon, etc.)
DATABASE_URL="postgresql://user:password@host:5432/dbname?pgbouncer=true"
# Direct URL for Prisma migrations (without connection pooler)
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# ── Auth (Required) ──────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET="your-jwt-secret-min-32-chars"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ── Admin Setup (Required) ───────────────────
# This email gets auto-promoted to ADMIN on first registration
ADMIN_EMAIL="your@email.com"

# ── AI Engines (At least one required for AI features) ──
GROQ_API_KEY=""        # https://console.groq.com (free tier available)
GEMINI_API_KEY=""      # https://aistudio.google.com

# ── OAuth Providers (Optional) ───────────────
# Create OAuth apps at: https://github.com/settings/developers
GITHUB_ID=""
GITHUB_SECRET=""
# Create OAuth app at: https://console.cloud.google.com
GOOGLE_ID=""
GOOGLE_SECRET=""

# ── Email (Optional) ─────────────────────────
# Nodemailer SMTP config for verification emails and alerts
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="NexPulse <noreply@yourdomain.com>"

# ── Rate Limiting (Optional — falls back to in-memory) ──
# https://upstash.com — free Redis tier available
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Security Alerts (Optional) ───────────────
# Discord webhook for brute force / security incident alerts
DISCORD_SECURITY_WEBHOOK=""

# ── Billing (Optional) ───────────────────────
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_WEBHOOK_SECRET=""

# ── Monitoring Cron (Optional) ───────────────
# Secret for the /api/cron/monitor endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET=""

# ── Sentry (Optional) ────────────────────────
SENTRY_DSN=""

# ── File Storage (Required for student ID card uploads) ──────────────────────
# Create a Blob store: https://vercel.com/dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=""

# ── Internal (Do not change) ─────────────────
# Used by the dashboard to trigger revalidations
REVALIDATE_SECRET=""
# Used by the /api/revalidate endpoint auth check
API_SECRET_KEY=""
