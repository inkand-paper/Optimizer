// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  apiKeys      ApiKey[]
  activityLogs ActivityLog[]
}

model ApiKey {
  id         String   @id @default(uuid())
  name       String
  keyHash    String   @unique // We store the hashed API key to compare against
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?
  
  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  type      String   // 'REVALIDATE', 'ANALYZE', 'AUTH', etc.
  action    String
  status    String   // 'SUCCESS', 'FAILURE'
  details   Json?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

