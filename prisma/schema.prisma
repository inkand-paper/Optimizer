// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  DEVELOPER
  VIEWER
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum CodeReviewSource {
  GITHUB
  ZIP
  PASTE
}

enum CodeReviewStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  name         String?
  role         Role     @default(DEVELOPER)
  plan         Plan     @default(FREE)
  image        String?
  emailVerified DateTime?
  verificationToken String? @unique
  resetToken        String? @unique
  resetTokenExpiry  DateTime?
  githubAccessToken String? //For code review Github connect (separate from login)
  githubUserName String?
  lemonSqueezyId String? // Added for billing
  subscriptionId String? // Added for plan tracking
  twoFactorSecret String? // Added for MFA
  twoFactorEnabled Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  accounts     Account[]
  sessions     Session[]
  apiKeys      ApiKey[]
  activityLogs ActivityLog[]
  monitors     Monitor[]
  webhooks     Webhook[]
  codeReviews CodeReview[]
  studentTrial StudentTrial?
  giftedTrial       GiftedTrial?
  statusPageSlug    String?  @unique  // custom slug; defaults to username/email prefix
  statusPageEnabled   Boolean  @default(false)
  weeklyDigestEnabled Boolean  @default(true)   // opt-out model — enabled by default
  lastDigestSentAt    DateTime?                  // prevents double-sends
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ... Role, User, Monitor, Check, ApiKey, ActivityLog models ...

model Webhook {
  id        String   @id @default(uuid())
  url       String
  events    String[] // REVALIDATE_SUCCESS, REVALIDATE_FAILURE, MONITOR_DOWN, MONITOR_UP
  secret    String?  // For payload signing
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}



// ... ApiKey and ActivityLog models ...

model Monitor {
  id          String   @id @default(uuid())
  name        String
  url         String
  status      String   @default("UP") // UP, DOWN, DEGRADED
  lastChecked DateTime?
  isPublic    Boolean  @default(true)  // shown on public status page unless hidden by user
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  checks      Check[]
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Check {
  id        String   @id @default(uuid())
  monitorId String
  monitor   Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status    String
  latency   Int      // in ms
  message   String?
  createdAt DateTime @default(now())

  @@index([monitorId])
}


model ApiKey {
  id         String   @id @default(uuid())
  name       String
  keyHash    String   @unique // We store the hashed API key to compare against
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?
  
  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  type      String   // 'REVALIDATE', 'ANALYZE', 'AUTH', etc.
  action    String
  status    String   // 'SUCCESS', 'FAILURE'
  details   Json?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

model CodeReview {
  id              String           @id @default(uuid())
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  source          CodeReviewSource // GITHUB | ZIP | PASTE
  repoUrl         String?
  repoName        String?
  repoBranch      String?          @default("main")
  fileName        String?
  status          CodeReviewStatus @default(PENDING)
  score           Int?
  language        String?
  linesOfCode     Int?
  filesReviewed   Int?
  result          Json?
  error           String?
  // Diff auditing — links this review to the previous one for the same source
  previousReviewId String?
  previousScore    Int?            // snapshot of previous score for delta calculation
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([userId, createdAt])
  @@index([userId, repoName])     // fast lookup of previous review for same repo
}

model AuditCache {
  id        String   @id @default(uuid())
  hash      String   @unique // MD5 of content
  path      String // Original path reference
  language  String
  review    Json // The FileReview object { score, summary, issues, positives }
  createdAt DateTime @default(now())

  @@index([hash])
}
model Promotion {
  id              String   @id @default(uuid())
  title           String   // e.g. "Black Friday — 40% off PRO"
  description     String?  // optional subtitle
  discountCode    String   // LemonSqueezy discount code
  discountPercent Int      // e.g. 40
  targetPlan      String   @default("ALL") // "PRO" | "BUSINESS" | "ALL"
  isActive        Boolean  @default(false)
  startsAt        DateTime
  endsAt          DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([isActive, endsAt])
}

enum StudentTrialStatus {
  PENDING
  APPROVED
  REJECTED
}

model StudentTrial {
  id              String             @id @default(uuid())
  userId          String             @unique
  eduEmail        String             @unique
  studentIdUrl    String?            // uploaded ID card file URL
  status          StudentTrialStatus @default(PENDING)
  rejectionReason String?            // preset reason code
  rejectionNote   String?            // optional custom note from admin
  reviewedAt      DateTime?          // when admin approved/rejected
  reviewedBy      String?            // admin user id who reviewed
  submittedAt     DateTime           @default(now())
  expiresAt       DateTime?          // set on approval: 30 days from reviewedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([eduEmail])
  @@index([status])
}

model GiftedTrial {
  id        String    @id @default(uuid())
  userId    String    @unique  // one active gift per user at a time
  giftedBy  String             // admin userId who gifted it
  plan      String    @default("PRO")
  reason    String?            // internal note e.g. "launch promo", "influencer"
  permanent Boolean   @default(false)
  expiresAt DateTime?          // null if permanent=true
  giftedAt  DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
