// This is your Prisma schema file.
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  DEVELOPER
  VIEWER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(DEVELOPER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  apiKeys      ApiKey[]
  activityLogs ActivityLog[]
  monitors     Monitor[]
  webhooks     Webhook[]
}

// ... Role, User, Monitor, Check, ApiKey, ActivityLog models ...

model Webhook {
  id        String   @id @default(uuid())
  url       String
  events    String[] // REVALIDATE_SUCCESS, REVALIDATE_FAILURE, MONITOR_DOWN, MONITOR_UP
  secret    String?  // For payload signing
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}



// ... ApiKey and ActivityLog models ...

model Monitor {
  id          String   @id @default(uuid())
  name        String
  url         String
  status      String   @default("UP") // UP, DOWN, DEGRADED
  lastChecked DateTime?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  checks      Check[]
  createdAt   DateTime @default(now())

  @@index([userId])
}

model Check {
  id        String   @id @default(uuid())
  monitorId String
  monitor   Monitor  @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status    String
  latency   Int      // in ms
  message   String?
  createdAt DateTime @default(now())

  @@index([monitorId])
}


model ApiKey {
  id         String   @id @default(uuid())
  name       String
  keyHash    String   @unique // We store the hashed API key to compare against
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime?
  
  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(uuid())
  type      String   // 'REVALIDATE', 'ANALYZE', 'AUTH', etc.
  action    String
  status    String   // 'SUCCESS', 'FAILURE'
  details   Json?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

